import pandas as pd
from sklearn.ensemble import RandomForestClassifier

# 1. Convert the dataset into a DataFrame
data = {
    'Hours_Studied': [2, 4, 7, 8, 10],
    'Absences': [8, 6, 2, 1, 0],
    'Result': [0, 0, 1, 1, 1]  # 0 = Fail, 1 = Pass
}

df = pd.DataFrame(data)

# 2. Split into X (features) and y (target)
X = df[['Hours_Studied', 'Absences']]
y = df['Result']

# 3. Train a RandomForestClassifier
# We use n_estimators=5 and random_state=42 as requested
model = RandomForestClassifier(n_estimators=5, random_state=42)
model.fit(X, y)

# 4. Predict outcomes and get probabilities
predictions = model.predict(X)
probabilities = model.predict_proba(X)

# 5. Output Results
print("Predictions:", predictions.tolist())

for row in probabilities:
    fail, pass_ = row
    # Round to 1 decimal place and format output
    print(f"[{fail:.1f} {pass_:.1f}]   # {int(round(fail, 1)*100)}% Fail, {int(round(pass_, 1)*100)}% Pass")

