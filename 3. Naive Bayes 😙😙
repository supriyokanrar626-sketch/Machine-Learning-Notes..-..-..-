import pandas as pd
from sklearn.feature_extraction.text import CountVectorizer
from sklearn.naive_bayes import MultinomialNB

# 1. Convert the dictionary into a pandas DataFrame
data = {
    "Message": [
        "Exclusive offer just for you",
        "Let's meet tomorrow morning",
        "Congratulations you won a prize",
        "Project review meeting at 5pm",
        "Free entry in a lucky draw"
    ],
    "Spam": [1, 0, 1, 0, 1]
}

df = pd.DataFrame(data)

# 2. Transform the text into numerical features using CountVectorizer
vectorizer = CountVectorizer()
X = vectorizer.fit_transform(df["Message"])
y = df["Spam"]

# Print Feature Names as requested
print("Feature Names:", vectorizer.get_feature_names_out().tolist())
print()

# 3. Train a Multinomial Naive Bayes model
model = MultinomialNB()
model.fit(X, y)

# 4. Generate predictions for the training dataset
predictions = model.predict(X)
probabilities = model.predict_proba(X)

# 5. Print the predictions and detailed results
print("Predictions:", predictions.tolist())
print()

for msg, prob in zip(df["Message"], probabilities):
    not_spam, spam = prob
    print(f"Message: {msg}")
    print(f"[{not_spam:.2f} {spam:.2f}]   # Probabilities\n")

